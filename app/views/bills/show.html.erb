<% content_for(:title) { "#{@bill.bill_number}: #{@bill.title} — Save Utah" } %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <%# === BACK LINK === %>
  <div class="mb-6">
    <%= link_to "← All Bills", bills_path, class: "text-utah-red hover:text-utah-red-dark font-medium text-sm" %>
  </div>

  <%# === BILL HEADER === %>
  <div class="bg-white rounded-xl shadow-sm border border-utah-sand-dark overflow-hidden">
    <div class="px-6 sm:px-8 py-8">
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="px-3 py-1 rounded-full text-xs font-bold bg-utah-navy text-white">
          <%= @bill.bill_number %>
        </span>
        <span class="px-3 py-1 rounded-full text-xs font-semibold <%= @bill.level_federal? ? 'bg-blue-100 text-blue-800' : 'bg-green-100 text-green-800' %>">
          <%= @bill.level_federal? ? "Federal" : "State" %>
        </span>
        <% if @bill.status.present? %>
          <span class="px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">
            <%= @bill.status %>
          </span>
        <% end %>
        <% if @bill.chamber.present? %>
          <span class="px-3 py-1 rounded-full text-xs font-semibold bg-utah-sand text-utah-navy">
            <%= @bill.chamber %>
          </span>
        <% end %>
      </div>

      <h1 class="text-3xl font-extrabold text-utah-navy"><%= @bill.title %></h1>

      <% if @bill.introduced_on.present? || @bill.session_name.present? %>
        <p class="mt-2 text-sm text-gray-500">
          <% if @bill.introduced_on.present? %>Introduced <%= @bill.introduced_on.strftime("%B %d, %Y") %><% end %>
          <% if @bill.session_name.present? %> &middot; <%= @bill.session_name %><% end %>
        </p>
      <% end %>
    </div>

    <%# === EDITORIAL SUMMARY (Why It Matters) === %>
    <% if @bill.has_editorial? %>
      <div class="mx-6 sm:mx-8 mb-6 bg-utah-gold-light/20 border border-utah-gold-light rounded-lg p-5">
        <h3 class="text-sm font-bold text-utah-gold-dark uppercase tracking-wider mb-2">Why This Matters</h3>
        <p class="text-gray-700 leading-relaxed"><%= @bill.editorial_summary %></p>
      </div>
    <% end %>

    <%# === BILL SUMMARY === %>
    <% if @bill.summary.present? %>
      <div class="px-6 sm:px-8 pb-6">
        <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-2">Official Summary</h3>
        <p class="text-gray-700 leading-relaxed"><%= @bill.summary %></p>
      </div>
    <% end %>

    <% if @bill.full_text_url.present? %>
      <div class="px-6 sm:px-8 pb-6">
        <%= link_to @bill.full_text_url, target: "_blank", rel: "noopener", class: "inline-flex items-center text-utah-sky-dark hover:text-utah-sky font-medium text-sm" do %>
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
          Read Full Text
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="mt-10 grid grid-cols-1 lg:grid-cols-3 gap-8">
    <%# === VOTE BREAKDOWN === %>
    <div class="lg:col-span-2">
      <h2 class="text-2xl font-bold text-utah-navy mb-4">Vote Breakdown</h2>

      <%# Vote summary bar %>
      <% if @votes.any? %>
        <div class="bg-white rounded-xl shadow-sm border border-utah-sand-dark p-6 mb-6">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
            <div>
              <div class="text-3xl font-black text-green-600"><%= @vote_summary[:yes] %></div>
              <div class="text-xs font-semibold text-gray-500 uppercase mt-1">Yea</div>
            </div>
            <div>
              <div class="text-3xl font-black text-red-600"><%= @vote_summary[:no] %></div>
              <div class="text-xs font-semibold text-gray-500 uppercase mt-1">Nay</div>
            </div>
            <div>
              <div class="text-3xl font-black text-gray-400"><%= @vote_summary[:abstain] %></div>
              <div class="text-xs font-semibold text-gray-500 uppercase mt-1">Abstain</div>
            </div>
            <div>
              <div class="text-3xl font-black text-gray-400"><%= @vote_summary[:not_voting] %></div>
              <div class="text-xs font-semibold text-gray-500 uppercase mt-1">Not Voting</div>
            </div>
          </div>

          <%# Visual bar %>
          <% total = @vote_summary.values.sum.to_f %>
          <% if total > 0 %>
            <div class="mt-4 flex rounded-full overflow-hidden h-3">
              <div class="bg-green-500" style="width: <%= (@vote_summary[:yes] / total * 100).round(1) %>%"></div>
              <div class="bg-red-500" style="width: <%= (@vote_summary[:no] / total * 100).round(1) %>%"></div>
              <div class="bg-gray-300" style="width: <%= ((@vote_summary[:abstain] + @vote_summary[:not_voting]) / total * 100).round(1) %>%"></div>
            </div>
          <% end %>
        </div>

        <%# Individual votes table %>
        <div class="bg-white rounded-xl shadow-sm border border-utah-sand-dark overflow-hidden">
          <table class="w-full">
            <thead class="bg-utah-sand">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Representative</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Party</th>
                <th class="px-4 py-3 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Vote</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-utah-sand-dark">
              <% @votes.each do |vote| %>
                <tr class="hover:bg-utah-sand-light transition-colors">
                  <td class="px-4 py-3">
                    <%= link_to vote.representative.full_name, representative_path(vote.representative),
                        class: "text-utah-navy font-medium hover:text-utah-red text-sm" %>
                    <div class="text-xs text-gray-500"><%= vote.representative.title %></div>
                  </td>
                  <td class="px-4 py-3">
                    <span class="text-sm text-gray-600"><%= vote.representative.party_abbrev %></span>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <span class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-bold <%= vote.position_css_class %>">
                      <%= vote.position_label %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="bg-white rounded-xl shadow-sm border border-utah-sand-dark p-8 text-center">
          <p class="text-gray-500">No vote data available yet for this bill.</p>
        </div>
      <% end %>
    </div>

    <%# === ACTION SCRIPTS SIDEBAR === %>
    <div>
      <h2 class="text-2xl font-bold text-utah-navy mb-4">Take Action</h2>
      <% if @action_scripts.any? %>
        <div class="space-y-4">
          <% @action_scripts.each do |script| %>
            <%= render "shared/script_card", script: script %>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white rounded-xl shadow-sm border border-utah-sand-dark p-6 text-center">
          <p class="text-gray-500 text-sm">No action scripts available for this bill yet.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
