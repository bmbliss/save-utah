<% content_for(:title) { "Bills & Votes — Save Utah" } %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <h1 class="text-3xl font-extrabold text-utah-navy">Bills & Votes</h1>
  <p class="mt-2 text-gray-600">Track legislation that affects Utah at the state and federal level</p>

  <%# === FILTERS === %>
  <div class="mt-8 bg-white rounded-xl shadow-sm border border-utah-sand-dark p-4 sm:p-6">
    <%= form_with url: bills_path, method: :get, class: "flex flex-col sm:flex-row flex-wrap gap-3 items-end", data: { turbo: false } do |f| %>
      <div class="flex-1 min-w-[180px]">
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Search</label>
        <%= f.text_field :search, value: params[:search], placeholder: "Search bills...",
            class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-utah-sky focus:ring-utah-sky text-sm" %>
      </div>
      <div class="min-w-[120px]">
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Level</label>
        <%= f.select :level, options_for_select([["All", ""], ["Federal", "federal"], ["State", "state"]], params[:level]),
            {}, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-utah-sky focus:ring-utah-sky text-sm" %>
      </div>
      <div class="min-w-[100px]">
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Year</label>
        <%= f.select :year, options_for_select([["All", ""]] + (2020..Date.today.year).to_a.reverse.map { |y| [y, y] }, params[:year]),
            {}, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-utah-sky focus:ring-utah-sky text-sm" %>
      </div>
      <div class="min-w-[120px]">
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Chamber</label>
        <%= f.select :chamber, options_for_select([["All", ""], ["Senate", "Senate"], ["House", "House"]], params[:chamber]),
            {}, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-utah-sky focus:ring-utah-sky text-sm" %>
      </div>
      <div>
        <%= f.submit "Filter", class: "px-6 py-2 bg-utah-red text-white font-semibold rounded-lg hover:bg-utah-red-dark transition-colors cursor-pointer text-sm" %>
      </div>
      <% if params.values_at(:search, :level, :year, :chamber, :status).any?(&:present?) %>
        <div>
          <%= link_to "Clear", bills_path, class: "px-4 py-2 text-gray-600 hover:text-utah-red font-medium text-sm" %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# === BILL LIST === %>
  <div class="mt-8 space-y-4">
    <% @bills.each do |bill| %>
      <%= render "shared/bill_card", bill: bill %>
    <% end %>
  </div>

  <% if @bills.empty? %>
    <div class="text-center py-12">
      <p class="text-gray-500 text-lg">No bills found matching your filters.</p>
      <%= link_to "Clear filters", bills_path, class: "mt-2 inline-block text-utah-red hover:text-utah-red-dark font-semibold" %>
    </div>
  <% end %>

  <%# === PAGINATION === %>
  <% if @pagy.last > 1 %>
    <div class="mt-8 flex justify-center">
      <%== @pagy.series_nav %>
    </div>
  <% end %>
</div>
