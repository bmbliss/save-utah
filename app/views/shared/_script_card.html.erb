<%# Shared action script card partial — used on homepage, rep show, and bill show %>
<div class="bg-white rounded-xl shadow-sm border border-utah-sand-dark p-5 hover:shadow-md transition-shadow">
  <div class="flex items-start gap-3">
    <%# Action type icon %>
    <div class="w-10 h-10 rounded-full flex-shrink-0 flex items-center justify-center
      <%= script.call? ? 'bg-utah-red-light/20 text-utah-red' : 'bg-utah-sky-light/30 text-utah-sky-dark' %>">
      <% if script.call? %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
      <% else %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      <% end %>
    </div>

    <div class="flex-1 min-w-0">
      <h3 class="font-bold text-utah-navy text-sm"><%= script.title %></h3>
      <% if script.context.present? %>
        <p class="mt-1 text-xs text-gray-500"><%= truncate(script.context, length: 100) %></p>
      <% end %>

      <%# Rendered script template %>
      <div class="mt-3 bg-utah-sand-light rounded-lg p-3 text-sm text-gray-700 leading-relaxed">
        "<%= script.render_script %>"
      </div>

      <%# CTA button %>
      <% if script.call? && (script.representative&.phone.present?) %>
        <div class="mt-3">
          <a href="tel:<%= script.representative.phone %>"
             class="inline-flex items-center px-4 py-2 bg-utah-red text-white text-xs font-bold rounded-lg hover:bg-utah-red-dark transition-colors">
            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            Call Now
          </a>
        </div>
      <% end %>
    </div>
  </div>
</div>
