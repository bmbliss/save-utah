<%# Shared representative card partial — used on homepage and index %>
<%= link_to representative_path(representative), class: "block bg-white rounded-xl shadow-sm border border-utah-sand-dark hover:shadow-md hover:border-utah-gold transition-all group overflow-hidden" do %>
  <div class="p-5">
    <div class="flex items-center gap-4">
      <%# Photo / initials %>
      <div class="w-14 h-14 rounded-full bg-utah-navy flex items-center justify-center overflow-hidden flex-shrink-0">
        <% if representative.photo_url.present? %>
          <img src="<%= representative.photo_url %>" alt="<%= representative.full_name %>" class="w-full h-full object-cover">
        <% else %>
          <span class="text-lg font-bold text-utah-gold">
            <%= representative.first_name&.first %><%= representative.last_name&.first %>
          </span>
        <% end %>
      </div>

      <div class="min-w-0">
        <h3 class="font-bold text-utah-navy group-hover:text-utah-red transition-colors truncate">
          <%= representative.full_name %>
        </h3>
        <p class="text-sm text-gray-600 truncate"><%= representative.title %></p>
      </div>
    </div>

    <div class="mt-3 flex flex-wrap gap-1.5">
      <span class="px-2 py-0.5 rounded-full text-xs font-semibold
        <%= representative.party == 'Republican' ? 'bg-red-100 text-red-700' : representative.party == 'Democrat' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-700' %>">
        <%= representative.party_abbrev %>
      </span>
      <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-utah-sand text-utah-navy">
        <%= representative.level_federal? ? "Federal" : "State" %>
      </span>
      <% if representative.district.present? %>
        <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-utah-sand text-utah-navy">
          Dist. <%= representative.district %>
        </span>
      <% end %>
    </div>

    <% if representative.phone.present? %>
      <div class="mt-3 text-xs text-gray-500 flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <%= representative.phone %>
      </div>
    <% end %>
  </div>
<% end %>
