<%# Blast Rep Card — mobile-first, one purpose: get someone to tap CALL
     Locals: representative, issue, score, call_script, text_script, email_script %>

<% rep = representative %>
<% score_val = score&.dig(:score) %>
<% best_phone = rep.phone_work.presence || rep.phone.presence || rep.phone_mobile.presence || rep.phone_home.presence %>

<div class="bg-white rounded-xl shadow-sm border border-utah-sand-dark overflow-hidden"
     data-controller="rep-card">

  <%# Header row: name, party, district, score %>
  <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100">
    <%# Photo / initials circle %>
    <div class="flex-shrink-0">
      <% if rep.photo_url.present? %>
        <img src="<%= rep.photo_url %>" alt="<%= rep.full_name %>"
             class="w-12 h-12 rounded-full object-cover border-2 border-utah-sand-dark">
      <% else %>
        <div class="w-12 h-12 rounded-full bg-utah-navy flex items-center justify-center text-white font-bold text-sm">
          <%= rep.first_name&.first %><%= rep.last_name&.first %>
        </div>
      <% end %>
    </div>

    <%# Name + metadata %>
    <div class="flex-1 min-w-0">
      <h3 class="font-bold text-utah-navy text-base leading-tight truncate">
        Sen. <%= rep.full_name %>
      </h3>
      <div class="flex items-center gap-2 mt-0.5">
        <span class="px-1.5 py-0.5 rounded text-xs font-bold bg-red-100 text-red-700">R</span>
        <% if rep.district.present? %>
          <span class="text-xs text-gray-500">District <%= rep.district %></span>
        <% end %>
      </div>
    </div>

    <%# Score badge %>
    <div class="flex-shrink-0 text-center">
      <div class="text-2xl font-black <%= score_val && score_val < 50 ? 'text-red-600' : score_val && score_val >= 50 ? 'text-green-600' : 'text-gray-400' %>">
        <%= score_val ? "#{score_val}%" : "N/A" %>
      </div>
      <div class="text-[10px] uppercase tracking-wider text-gray-400 font-semibold">Score</div>
    </div>
  </div>

  <%# Three action buttons — CALL / TEXT / EMAIL %>
  <div class="grid grid-cols-3 divide-x divide-gray-100">
    <%# CALL button %>
    <% if best_phone.present? %>
      <a href="tel:<%= best_phone.gsub(/[^\d+]/, '') %>"
         class="flex flex-col items-center justify-center gap-1 py-3.5 bg-red-600 hover:bg-red-700 text-white transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <span class="text-xs font-bold uppercase tracking-wider">Call</span>
      </a>
    <% else %>
      <div class="flex flex-col items-center justify-center gap-1 py-3.5 bg-gray-100 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <span class="text-xs font-bold uppercase tracking-wider">Call</span>
      </div>
    <% end %>

    <%# TEXT button %>
    <% if best_phone.present? && text_script.present? %>
      <% sms_body = text_script.render_script(representative: rep).gsub(/^Subject:.*\n*/, '') %>
      <a href="sms:<%= best_phone.gsub(/[^\d+]/, '') %>&body=<%= ERB::Util.url_encode(sms_body) %>"
         class="flex flex-col items-center justify-center gap-1 py-3.5 bg-green-600 hover:bg-green-700 text-white transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        <span class="text-xs font-bold uppercase tracking-wider">Text</span>
      </a>
    <% else %>
      <div class="flex flex-col items-center justify-center gap-1 py-3.5 bg-gray-100 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        <span class="text-xs font-bold uppercase tracking-wider">Text</span>
      </div>
    <% end %>

    <%# EMAIL button %>
    <% if rep.email.present? && email_script.present? %>
      <% rendered_email = email_script.render_script(representative: rep) %>
      <% email_subject = rendered_email[/^Subject:\s*(.+)$/i, 1] || "Your vote on HB 497" %>
      <% email_body = rendered_email.gsub(/^Subject:.*\n*/, '').strip %>
      <a href="mailto:<%= rep.email %>?subject=<%= ERB::Util.url_encode(email_subject) %>&body=<%= ERB::Util.url_encode(email_body) %>"
         class="flex flex-col items-center justify-center gap-1 py-3.5 bg-sky-600 hover:bg-sky-700 text-white transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <span class="text-xs font-bold uppercase tracking-wider">Email</span>
      </a>
    <% else %>
      <div class="flex flex-col items-center justify-center gap-1 py-3.5 bg-gray-100 text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <span class="text-xs font-bold uppercase tracking-wider">Email</span>
      </div>
    <% end %>
  </div>

  <%# Expandable phone numbers %>
  <% if rep.phone_numbers.any? %>
    <div class="border-t border-gray-100">
      <button class="w-full px-4 py-2 text-xs text-gray-500 hover:text-utah-navy font-semibold flex items-center justify-center gap-1 transition-colors"
              data-action="click->rep-card#toggle">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
        All phone numbers
      </button>
      <div class="hidden px-4 pb-3 space-y-1" data-rep-card-target="details">
        <% rep.phone_numbers.each do |pn| %>
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-500"><%= pn[:label] %></span>
            <a href="tel:<%= pn[:number].gsub(/[^\d+]/, '') %>" class="text-utah-red font-semibold hover:underline">
              <%= pn[:number] %>
            </a>
          </div>
        <% end %>
        <% if rep.email.present? %>
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-500">Email</span>
            <a href="mailto:<%= rep.email %>" class="text-sky-600 font-semibold hover:underline truncate ml-2">
              <%= rep.email %>
            </a>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
