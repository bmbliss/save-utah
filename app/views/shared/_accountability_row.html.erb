<%# Accountability scorecard row — one per representative %>
<%# Locals: representative, issue, issue_bills, votes_lookup, score %>
<tr class="hover:bg-utah-sand/30 transition-colors">
  <%# Rep name + party — sticky on mobile %>
  <td class="sticky left-0 z-10 bg-white px-4 py-3 whitespace-nowrap">
    <div class="flex items-center gap-3">
      <%# Photo / initials %>
      <div class="w-9 h-9 rounded-full bg-utah-navy flex items-center justify-center overflow-hidden flex-shrink-0">
        <% if representative.photo_url.present? %>
          <img src="<%= representative.photo_url %>" alt="<%= representative.full_name %>" class="w-full h-full object-cover">
        <% else %>
          <span class="text-xs font-bold text-utah-gold">
            <%= representative.first_name&.first %><%= representative.last_name&.first %>
          </span>
        <% end %>
      </div>

      <div class="min-w-0">
        <%= link_to representative.full_name, representative_path(representative),
            class: "font-bold text-utah-navy hover:text-utah-red transition-colors text-sm" %>
        <div class="flex items-center gap-1 mt-0.5">
          <span class="px-1.5 py-0.5 rounded text-[10px] font-bold
            <%= representative.party == 'Republican' ? 'bg-red-100 text-red-700' : representative.party == 'Democrat' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-700' %>">
            <%= representative.party_abbrev %>
          </span>
          <% if representative.district.present? %>
            <span class="text-[10px] text-gray-400">Dist. <%= representative.district %></span>
          <% end %>
        </div>
      </div>
    </div>
  </td>

  <%# Vote cells — one per bill %>
  <% issue_bills.each do |ib| %>
    <% vote = votes_lookup[[representative.id, ib.bill_id]] %>
    <td class="px-4 py-3 text-center">
      <span class="inline-block px-2.5 py-1 rounded-md text-xs font-bold <%= issue.vote_alignment_css(vote, ib) %>">
        <% if vote %>
          <%= vote.position_label %>
        <% else %>
          —
        <% end %>
      </span>
    </td>
  <% end %>

  <%# Score %>
  <td class="px-4 py-3 text-center">
    <% if score[:score] %>
      <span class="text-lg font-black <%= score[:score] >= 50 ? 'text-green-600' : 'text-red-600' %>">
        <%= score[:score] %>%
      </span>
    <% else %>
      <span class="text-sm text-gray-400">N/A</span>
    <% end %>
  </td>

  <%# Contact %>
  <td class="px-4 py-3">
    <div class="flex flex-col gap-1">
      <%# Phone links %>
      <% representative.phone_numbers.each do |pn| %>
        <a href="tel:<%= pn[:number].gsub(/[^\d+]/, '') %>"
           class="inline-flex items-center gap-1 text-xs text-utah-navy hover:text-utah-red transition-colors whitespace-nowrap"
           title="Call (<%= pn[:label] %>)">
          <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <%= pn[:number] %>
        </a>
      <% end %>

      <%# Email link %>
      <% if representative.email.present? %>
        <a href="mailto:<%= representative.email %>?subject=<%= ERB::Util.url_encode("Re: #{issue.name}") %>"
           class="inline-flex items-center gap-1 text-xs text-utah-navy hover:text-utah-red transition-colors whitespace-nowrap"
           title="Email">
          <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Email
        </a>
      <% end %>
    </div>
  </td>
</tr>
