<% content_for(:title) { "#{@representative.display_name} — Save Utah" } %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <%# === BACK LINK === %>
  <div class="mb-6">
    <%= link_to "← All Representatives", representatives_path, class: "text-utah-red hover:text-utah-red-dark font-medium text-sm" %>
  </div>

  <%# === PROFILE HEADER === %>
  <div class="bg-white rounded-xl shadow-sm border border-utah-sand-dark overflow-hidden">
    <div class="bg-gradient-to-r from-utah-navy to-utah-navy-dark px-6 sm:px-8 py-8">
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <%# Photo or initials %>
        <div class="w-24 h-24 rounded-full bg-utah-navy-light border-3 border-utah-gold flex items-center justify-center overflow-hidden flex-shrink-0">
          <% if @representative.photo_url.present? %>
            <img src="<%= @representative.photo_url %>" alt="<%= @representative.full_name %>" class="w-full h-full object-cover">
          <% else %>
            <span class="text-3xl font-bold text-utah-gold">
              <%= @representative.first_name&.first %><%= @representative.last_name&.first %>
            </span>
          <% end %>
        </div>
        <div>
          <h1 class="text-3xl font-extrabold text-white"><%= @representative.full_name %></h1>
          <p class="mt-1 text-lg text-utah-gold"><%= @representative.title %></p>
          <div class="mt-2 flex flex-wrap gap-2">
            <span class="px-3 py-1 rounded-full text-xs font-semibold
              <%= @representative.party == 'Republican' ? 'bg-red-100 text-red-800' : @representative.party == 'Democrat' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
              <%= @representative.party %>
            </span>
            <span class="px-3 py-1 rounded-full text-xs font-semibold bg-utah-navy-light text-gray-300">
              <%= @representative.level_federal? ? "Federal" : "State" %>
            </span>
            <% if @representative.district.present? %>
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-utah-navy-light text-gray-300">
                District <%= @representative.district %>
              </span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <%# === CONTACT INFO === %>
    <div class="px-6 sm:px-8 py-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% if @representative.phone.present? %>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-utah-sage-light flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-utah-sage-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold">Phone</p>
            <a href="tel:<%= @representative.phone %>" class="text-utah-navy font-medium hover:text-utah-red"><%= @representative.phone %></a>
          </div>
        </div>
      <% end %>

      <% if @representative.email.present? %>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-utah-sky-light/30 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-utah-sky-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold">Email</p>
            <a href="mailto:<%= @representative.email %>" class="text-utah-navy font-medium hover:text-utah-red truncate"><%= @representative.email %></a>
          </div>
        </div>
      <% end %>

      <% if @representative.website_url.present? %>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-utah-gold-light/30 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-utah-gold-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold">Website</p>
            <%= link_to "Official Website", @representative.website_url, target: "_blank", rel: "noopener", class: "text-utah-navy font-medium hover:text-utah-red" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-10 grid grid-cols-1 lg:grid-cols-3 gap-8">
    <%# === VOTING RECORD === %>
    <div class="lg:col-span-2">
      <h2 class="text-2xl font-bold text-utah-navy mb-4">Voting Record</h2>
      <% if @votes.any? %>
        <div class="bg-white rounded-xl shadow-sm border border-utah-sand-dark overflow-hidden">
          <table class="w-full">
            <thead class="bg-utah-sand">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Bill</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Date</th>
                <th class="px-4 py-3 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Vote</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-utah-sand-dark">
              <% @votes.each do |vote| %>
                <tr class="hover:bg-utah-sand-light transition-colors">
                  <td class="px-4 py-3">
                    <%= link_to vote.bill.title, bill_path(vote.bill), class: "text-utah-navy font-medium hover:text-utah-red text-sm" %>
                    <div class="text-xs text-gray-500"><%= vote.bill.bill_number %></div>
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap">
                    <%= vote.voted_on&.strftime("%b %d, %Y") || "—" %>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <span class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-bold <%= vote.position_css_class %>">
                      <%= vote.position_label %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="bg-white rounded-xl shadow-sm border border-utah-sand-dark p-8 text-center">
          <p class="text-gray-500">No voting records available yet.</p>
        </div>
      <% end %>
    </div>

    <%# === ACTION SCRIPTS SIDEBAR === %>
    <div>
      <h2 class="text-2xl font-bold text-utah-navy mb-4">Take Action</h2>
      <% if @action_scripts.any? %>
        <div class="space-y-4">
          <% @action_scripts.each do |script| %>
            <%= render "shared/script_card", script: script %>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white rounded-xl shadow-sm border border-utah-sand-dark p-6 text-center">
          <% if @representative.phone.present? %>
            <p class="text-gray-600 text-sm mb-3">Call your representative directly:</p>
            <a href="tel:<%= @representative.phone %>" class="inline-flex items-center px-6 py-3 bg-utah-red text-white font-bold rounded-lg hover:bg-utah-red-dark transition-colors">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              Call <%= @representative.last_name %>
            </a>
          <% else %>
            <p class="text-gray-500 text-sm">No action scripts available yet.</p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
